{
  "name": "codex-pet-meter",
  "version": "0.3.0",
  "description": "macOS pet overlay for Codex and Claude usage",
  "type": "module",
  "main": "install.mjs",
  "scripts": {
    "check": "node --check install.mjs && bash -n setup.sh && /usr/bin/swiftc -typecheck -framework Cocoa app/CodexUsageHalo.swift",
    "ci": "npm run check",
    "install-app": "node install.mjs install",
    "start": "node install.mjs start",
    "status": "node install.mjs status",
    "uninstall": "node install.mjs uninstall"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rain2day/codex-pet-meter.git"
  },
  "author": "rain2day",
  "keywords": [
    "macos",
    "overlay",
    "codex",
    "claude",
    "openai",
    "usage",
    "usage-meter",
    "swift",
    "appkit",
    "local-first",
    "menu-bar"
  ]
}
